                                <div class="feature-icon">
                                    <i class="fas fa-shield-alt"></i>
                                </div>
                                <h5>Secure Access</h5>
                                <p>OAuth 2.0 client credentials flow with JWT tokens and refresh token support.</p>
                            </div>
                        </div>
                        <div class="col-md-4 mb-4">
                            <div class="text-center">
                                <div class="feature-icon">
                                    <i class="fas fa-exchange-alt"></i>
                                </div>
                                <h5>SDMX Standard</h5>
                                <p>Full SDMX 2.1 compliance for statistical data exchange in XML and JSON formats.</p>
                            </div>
                        </div>
                        <div class="col-md-4 mb-4">
                            <div class="text-center">
                                <div class="feature-icon">
                                    <i class="fas fa-clock"></i>
                                </div>
                                <h5>Real-time Data</h5>
                                <p>Access to current economic indicators, prices, and statistical information.</p>
                            </div>
                        </div>
                    </div>
                </section>

                <!-- Base URL -->
                <section id="base-url" class="mb-4">
                    <div class="card endpoint-card">
                        <div class="card-header d-flex justify-content-between align-items-center">
                            <h5 class="mb-0"><i class="fas fa-link me-2"></i>Base URL</h5>
                        </div>
                        <div class="card-body">
                            <div class="position-relative">
                                <pre class="response-example"><code class="language-none">@ViewBag.baseUrl</code></pre>
                                <button class="copy-btn" onclick="copyToClipboard(this)">Copy</button>
                            </div>
                            <p class="text-muted mb-0">Use this as the prefix for all endpoints listed below.</p>
                        </div>
                    </div>
                </section>

                <!-- Authentication Section -->
                <section id="authentication" class="mb-5">
                    <h2 class="section-title">Authentication</h2>

                    <!-- Token Endpoint -->
                    <div class="card endpoint-card">
                        <div class="card-header d-flex justify-content-between align-items-center">
                            <h5 class="mb-0"><i class="fas fa-key me-2"></i>Get Access Token</h5>
                            <span class="method-badge method-post">POST</span>
                        </div>
                        <div class="card-body">
                            <div class="position-relative">
                                <pre class="response-example"><code class="language-none">https://www.cbsl.lk/openapi/connect/token</code></pre>
                                <button class="copy-btn" onclick="copyToClipboard(this)">Copy</button>
                            </div>
                            <p>Obtain an access token using OAuth 2.0 client credentials flow.</p>

                            <h6 class="mt-4">Request Parameters (Form-encoded)</h6>
                            <table class="table table-bordered param-table">
                                <thead>
                                    <tr>
                                        <th>Parameter</th>
                                        <th>Type</th>
                                        <th>Required</th>
                                        <th>Description</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr>
                                        <td><code>grant_type</code></td>
                                        <td>string</td>
                                        <td>Yes</td>
                                        <td>Must be "client_credentials"</td>
                                    </tr>
                                    <tr>
                                        <td><code>client_id</code></td>
                                        <td>string</td>
                                        <td>Yes</td>
                                        <td>Your client identifier</td>
                                    </tr>
                                    <tr>
                                        <td><code>client_secret</code></td>
                                        <td>string</td>
                                        <td>Yes</td>
                                        <td>Your client secret</td>
                                    </tr>
                                    <tr>
                                        <td><code>scope</code></td>
                                        <td>string</td>
                                        <td>No</td>
                                        <td>Space-separated scope values</td>
                                    </tr>
                                </tbody>
                            </table>

                            <h6 class="mt-4">Example Request</h6>
                            <div class="position-relative">
                                <pre class="response-example"><code class="language-bash">curl -X POST https://www.cbsl.lk/openapi/connect/token \
  -H "Content-Type: application/x-www-form-urlencoded" \
  -d "grant_type=client_credentials&client_id=YOUR_CLIENT_ID&client_secret=YOUR_SECRET"</code></pre>
                                <button class="copy-btn" onclick="copyToClipboard(this)">Copy</button>
                            </div>

                            <h6 class="mt-4">Response</h6>
                            <div class="position-relative">
                                <pre class="response-example"><code class="language-json">{
  "access_token": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...",
  "token_type": "Bearer",
  "expires_in": 3600,
  "scope": "statistics datalibrary",
  "refresh_token": "a1b2c3d4e5f6...",
  "refresh_token_expires_in": 2592000
}</code></pre>
                                <button class="copy-btn" onclick="copyToClipboard(this)">Copy</button>
                            </div>

                            <h6 class="mt-4">Response Codes</h6>
                            <span class="status-code status-200">200 OK</span>
                            <span class="status-code status-400">400 Bad Request</span>
                            <span class="status-code status-401">401 Unauthorized</span>
                        </div>
                    </div>

                    <!-- Refresh Token Endpoint -->
                    <div class="card endpoint-card">
                        <div class="card-header d-flex justify-content-between align-items-center">
                            <h5 class="mb-0"><i class="fas fa-refresh me-2"></i>Refresh Access Token</h5>
                            <span class="method-badge method-post">POST</span>
                        </div>
                        <div class="card-body">
                            <div class="position-relative">
                                <pre class="response-example"><code class="language-none">https://www.cbsl.lk/openapi/connect/refresh/token</code></pre>
                                <button class="copy-btn" onclick="copyToClipboard(this)">Copy</button>
                            </div>
                            <p>Refresh an expired access token using a refresh token.</p>

                            <h6 class="mt-4">Request Parameters (Form-encoded)</h6>
                            <table class="table table-bordered param-table">
                                <thead>
                                    <tr>
                                        <th>Parameter</th>
                                        <th>Type</th>
                                        <th>Required</th>
                                        <th>Description</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr>
                                        <td><code>grant_type</code></td>
                                        <td>string</td>
                                        <td>Yes</td>
                                        <td>Must be "refresh_token"</td>
                                    </tr>
                                    <tr>
                                        <td><code>client_id</code></td>
                                        <td>string</td>
                                        <td>Yes</td>
                                        <td>Your client identifier</td>
                                    </tr>
                                    <tr>
                                        <td><code>refresh_token</code></td>
                                        <td>string</td>
                                        <td>Yes</td>
                                        <td>Your refresh token</td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </section>

                <!-- Exchange Rates -->
                    <div id="exchange-rates" class="card endpoint-card">
                        <div class="card-header d-flex justify-content-between align-items-center">
                            <h5 class="mb-0"><i class="fas fa-exchange-alt me-2"></i>Get Exchange Rates</h5>
                            <span class="method-badge method-get">GET</span>
                        </div>
                        <div class="card-body">
                            <div class="position-relative">
                                <pre class="response-example"><code class="language-none">/api/v1/datalibrary/exchangerates</code></pre>
                                <button class="copy-btn" onclick="copyToClipboard(this)">Copy</button>
                            </div>
                            <p>Get buying and selling exchange rates for specified currency and date range.</p>

                            <h6 class="mt-4">Query Parameters</h6>
                            <table class="table table-bordered param-table">
                                <thead>
                                    <tr>
                                        <th>Parameter</th>
                                        <th>Type</th>
                                        <th>Required</th>
                                        <th>Description</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr>
                                        <td><code>currencyCode</code></td>
                                        <td>string</td>
                                        <td>Yes</td>
                                        <td>3-letter currency code (e.g., USD, EUR)</td>
                                    </tr>
                                    <tr>
                                        <td><code>typeLike</code></td>
                                        <td>string</td>
                                        <td>Yes</td>
                                        <td>Exchange rate type (e.g., "ex-bs")</td>
                                    </tr>
                                    <tr>
                                        <td><code>fromDate</code></td>
                                        <td>string</td>
                                        <td>Yes</td>
                                        <td>Start date (yyyy-MM-dd format)</td>
                                    </tr>
                                    <tr>
                                        <td><code>toDate</code></td>
                                        <td>string</td>
                                        <td>No</td>
                                        <td>End date (yyyy-MM-dd format)</td>
                                    </tr>
                                </tbody>
                            </table>

                            <h6 class="mt-4">Example</h6>
                            <div class="nav nav-tabs" role="tablist">
                                <a class="nav-link active" data-bs-toggle="tab" href="#exchange-json" role="tab">JSON Example</a>
                                <a class="nav-link" data-bs-toggle="tab" href="#exchange-sdmx" role="tab">SDMX Example</a>
                            </div>
                            <div class="tab-content">
                                <div class="tab-pane fade show active" id="exchange-json">
                                    <h6>JSON Request</h6>
                                    <div class="position-relative">
                                        <pre class="response-example"><code class="language-bash">curl -X GET "/api/v1/datalibrary/exchangerates?currencyCode=USD&typeLike=ex-bs&fromDate=2024-01-01&toDate=2024-01-31"</code></pre>
                                        <button class="copy-btn" onclick="copyToClipboard(this)">Copy</button>
                                    </div>
                                    <h6>JSON Response</h6>
                                    <div class="position-relative" style="max-height: 400px; overflow-y: auto; border: 1px solid #374151; border-radius: 4px;">
                                        <pre class="response-example" style="margin: 0;" data-example-url="@ViewBag.baseUrl/examples/exchange-rates.json">
                                            <code class="language-json">Loading...</code>
                                        </pre>
                                        <button class="copy-btn" onclick="copyToClipboard(this)">Copy</button>
                                    </div>
                                </div>
                                <div class="tab-pane fade" id="exchange-sdmx">
                                    <h6>SDMX Request</h6>
                                    <div class="position-relative">
                                        <pre class="response-example"><code class="language-bash">curl -X GET "/api/v1/datalibrary/exchangerates?currencyCode=USD&typeLike=ex-bs&fromDate=2024-01-01&toDate=2024-01-31&format=sdmx"</code></pre>
                                        <button class="copy-btn" onclick="copyToClipboard(this)">Copy</button>
                                    </div>
                                    <h6>SDMX Response</h6>
