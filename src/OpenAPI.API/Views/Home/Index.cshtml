                                        <button class="btn btn-outline-secondary btn-sm" id="gdpDownloadCsv" disabled>Download CSV</button>
                                    </div>

                                    <script>
                                        (() => {
                                            const frequencySelect = document.getElementById('gdpFrequencySelect');
                                            const periodInput = document.getElementById('gdpPeriodInput');
                                            const yearInput = document.getElementById('gdpYearInput');
                                            const quarterInput = document.getElementById('gdpQuarterInput');
                                            const formatSelect = document.getElementById('gdpFormatSelect');
                                            const resultEl = document.getElementById('gdpResult');
                                            const statusEl = document.getElementById('gdpStatus');
                                            const jsonBtn = document.getElementById('gdpDownloadJson');
                                            const csvBtn = document.getElementById('gdpDownloadCsv');
                                            const callBtn = document.getElementById('gdpCallBtn');

                                            const baseUrl = '@ViewBag.baseUrl';
                                            const basePath = baseUrl +'/api/v1/statistics/weekly/economic-indicator/gdp-growth';
                                            let lastPayload = null;

                                            const toggleDownloads = (enabled) => {
                                                jsonBtn.disabled = !enabled;
                                                csvBtn.disabled = !enabled;
                                            };

                                            const getData = (payload) => payload?.data ?? payload?.Data ?? null;
                                            const getPeriod = (payload) => payload?.period ?? payload?.Period ?? '';
                                            const getFrequency = (payload) => payload?.frequency ?? payload?.Frequency ?? '';

                                            const csvEscape = (val) => {
                                                const str = String(val ?? '');
                                                if (str.includes('"') || str.includes(',') || str.includes('\n')) {
                                                    return '"' + str.replace(/"/g, '""') + '"';
                                                }
                                                return str;
                                            };

                                            const toCsv = (payload) => {
                                                const data = getData(payload);
                                                if (!payload || !data) {
                                                    return '';
                                                }
                                                const rows = Object.entries(data).map(([item, value]) => ({
                                                    Period: getPeriod(payload),
                                                    Frequency: getFrequency(payload),
                                                    Item: item,
                                                    Value: value
                                                }));
                                                const header = 'Period,Frequency,Item,Value';
                                                const body = rows.map((r) => `${csvEscape(r.Period)},${csvEscape(r.Frequency)},${csvEscape(r.Item)},${r.Value}`);
                                                return [header, ...body].join('\n');
                                            };

                                            const callApi = async () => {
                                                toggleDownloads(false);
                                                statusEl.textContent = 'Calling...';
                                                resultEl.textContent = 'Loading...';

                                                const params = new URLSearchParams();
                                                params.set('frequency', frequencySelect.value || 'A');
                                                if (periodInput.value) {
                                                    params.set('period', periodInput.value);
                                                }
                                                if (yearInput.value) {
                                                    params.set('year', yearInput.value);
                                                }
                                                if (quarterInput.value) {
                                                    params.set('quarter', quarterInput.value);
                                                }
                                                if (formatSelect.value) {
                                                    params.set('format', formatSelect.value);
                                                }

                                                const url = `${basePath}?${params.toString()}`;

                                                try {
                                                    const res = await fetch(url);
                                                    const text = await res.text();
                                                    statusEl.textContent = `Status: ${res.status}`;

                                                    try {
                                                        lastPayload = JSON.parse(text);
                                                        resultEl.textContent = JSON.stringify(lastPayload, null, 2);
                                                        toggleDownloads(!!getData(lastPayload));
                                                    } catch (_) {
                                                        lastPayload = null;
                                                        resultEl.textContent = text || 'No content';
                                                        toggleDownloads(false);
                                                    }
                                                } catch (err) {
                                                    lastPayload = null;
                                                    statusEl.textContent = 'Call failed';
                                                    resultEl.textContent = `Error: ${err}`;
                                                    toggleDownloads(false);
                                                }
                                            };

                                            const downloadJson = () => {
                                                if (!lastPayload) {
                                                    return;
                                                }
                                                const blob = new Blob([JSON.stringify(lastPayload, null, 2)], { type: 'application/json' });
                                                const link = document.createElement('a');
                                                link.href = URL.createObjectURL(blob);
                                                link.download = 'gdp-growth.json';
                                                link.click();
                                                URL.revokeObjectURL(link.href);
                                            };

                                            const downloadCsv = () => {
                                                if (!lastPayload) {
                                                    return;
                                                }
                                                const csv = toCsv(lastPayload);
                                                if (!csv) {
                                                    return;
                                                }
                                                const blob = new Blob([csv], { type: 'text/csv' });
                                                const link = document.createElement('a');
                                                link.href = URL.createObjectURL(blob);
                                                link.download = 'gdp-growth.csv';
                                                link.click();
                                                URL.revokeObjectURL(link.href);
                                            };

                                            callBtn.addEventListener('click', callApi);
                                            jsonBtn.addEventListener('click', downloadJson);
                                            csvBtn.addEventListener('click', downloadCsv);
                                        })();
                                    </script>
                                </div>
                            </div>

