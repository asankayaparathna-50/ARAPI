    <!-- Scripts -->
    <script src="~/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/prism-core.min.js"></script>
    <script src="~/js/prism-autoloader.min.js"></script>

    <script>
        // Copy to clipboard functionality
        function copyToClipboard(button) {
            const codeBlock = button.previousElementSibling.querySelector('code');
            const text = codeBlock.textContent;

            navigator.clipboard.writeText(text).then(() => {
                const originalText = button.textContent;
                button.textContent = 'Copied!';
                button.style.background = '#27ae60';

                setTimeout(() => {
                    button.textContent = originalText;
                    button.style.background = '#3498db';
                }, 2000);
            }).catch(err => {
                console.error('Failed to copy: ', err);
            });
        }

        // Section-by-section navigation mode
        document.addEventListener('DOMContentLoaded', () => {
            const contentRoot = document.querySelector('.col-lg-9.col-md-8');
            const overviewSection = document.getElementById('overview');
            const statisticsSection = document.getElementById('statistics');

            const topLevelBlocks = contentRoot
                ? Array.from(contentRoot.children).filter(el =>
                    el.matches('section[id], .endpoint-card[id], .card.endpoint-card[id]')
                )
                : [];

            const statisticsCards = statisticsSection
                ? Array.from(statisticsSection.querySelectorAll('.endpoint-card[id]'))
                : [];

            const menuLinks = document.querySelectorAll('.sidebar a.nav-link[href^="#"], .navbar a.nav-link[href^="#"]');

            const setActiveLink = (targetId) => {
                menuLinks.forEach(link => {
                    const href = link.getAttribute('href');
                    link.classList.toggle('active', href === `#${targetId}`);
                });
            };

            const hideAllPanels = () => {
                topLevelBlocks.forEach(block => {
                    block.style.display = 'none';
                });

                statisticsCards.forEach(card => {
                    card.style.display = 'none';
                });
            };

            const showOverviewOnly = (shouldScroll = true) => {
                hideAllPanels();

                if (overviewSection) {
                    overviewSection.style.display = 'block';
                    if (shouldScroll) {
                        overviewSection.scrollIntoView({ behavior: 'smooth', block: 'start' });
                    }
                    setActiveLink('overview');
                }
            };

            const showPanelById = (targetId) => {
                if (!targetId) {
                    showOverviewOnly();
                    return;
                }

                hideAllPanels();

                const directBlock = topLevelBlocks.find(block => block.id === targetId);
                if (directBlock) {
                    directBlock.style.display = 'block';

                    if (targetId === 'statistics') {
                        statisticsCards.forEach(card => {
                            card.style.display = 'block';
                        });
                    }

                    directBlock.scrollIntoView({ behavior: 'smooth', block: 'start' });
                    setActiveLink(targetId);
                    return;
                }

                const statisticsCard = statisticsCards.find(card => card.id === targetId);
                if (statisticsCard && statisticsSection) {
                    statisticsSection.style.display = 'block';
                    statisticsCard.style.display = 'block';
                    statisticsSection.scrollIntoView({ behavior: 'smooth', block: 'start' });
                    setActiveLink(targetId);
                    return;
                }

                if (targetId === 'endpoints' && statisticsSection) {
                    statisticsSection.style.display = 'block';
                    statisticsCards.forEach(card => {
                        card.style.display = 'block';
                    });
                    statisticsSection.scrollIntoView({ behavior: 'smooth', block: 'start' });
                    setActiveLink('statistics');
                    return;
                }

                showOverviewOnly();
            };

            menuLinks.forEach(link => {
                link.addEventListener('click', (e) => {
                    const href = link.getAttribute('href');
                    if (!href || !href.startsWith('#')) {
                        return;
                    }

                    e.preventDefault();
                    const targetId = href.substring(1);
                    showPanelById(targetId);
                });
            });

            const initialHash = window.location.hash?.replace('#', '').trim();
            if (initialHash) {
                showPanelById(initialHash);
            } else {
                showOverviewOnly(false);
            }

            // Lazy-load example payloads into code blocks
            const examples = document.querySelectorAll('pre[data-example-url]');
            examples.forEach(pre => {
                const codeEl = pre.querySelector('code');
                const url = pre.dataset.exampleUrl || '';
                if (!codeEl || !url) {
                    return;
                }

                const resolvedUrl = url.startsWith('~/') ? url.replace('~', '') : url;

                fetch(resolvedUrl)
                    .then(response => {
                        if (!response.ok) {
                            throw new Error(`HTTP ${response.status}`);
                        }
                        return response.text();
                    })
                    .then(text => {
                        codeEl.textContent = text;
                        Prism.highlightElement(codeEl);
                    })
                    .catch(() => {
                        codeEl.textContent = 'Failed to load example.';
                    });
            });

            // Daily indicators try widgets
            const initDailyTryWidgets = () => {
                const widgets = document.querySelectorAll('.daily-try-widget');
                widgets.forEach(widget => {
                    if (widget.dataset.bound === '1') {
                        return;
                    }
                    widget.dataset.bound = '1';

                    const endpoint = widget.dataset.endpoint || '';
                    const fileName = widget.dataset.fileName || 'daily-indicator';
                    const periodInput = widget.querySelector('.daily-try-period');
                    const formatSelect = widget.querySelector('.daily-try-format');
                    const callBtn = widget.querySelector('.daily-try-call');
                    const statusEl = widget.querySelector('.daily-try-status');
                    const resultEl = widget.querySelector('.daily-try-result');
                    const jsonBtn = widget.querySelector('.daily-try-download-json');
                    const csvBtn = widget.querySelector('.daily-try-download-csv');
                    const extraParams = Array.from(widget.querySelectorAll('.daily-try-param'));
                    const baseUrl = '@ViewBag.baseUrl';

                    let lastPayload = null;

                    const toggleDownloads = (enabled) => {
                        if (jsonBtn) {
                            jsonBtn.disabled = !enabled;
                        }
                        if (csvBtn) {
                            csvBtn.disabled = !enabled;
                        }
                    };

                    const getData = (payload) => payload?.Data ?? payload?.data ?? payload ?? null;

                    const flattenObject = (obj, path = '') => {
                        if (obj === null || obj === undefined) {
                            return [];
                        }
                        if (typeof obj !== 'object') {
                            return [{ metric: path || 'value', value: obj }];
                        }
                        if (Array.isArray(obj)) {
                            return obj.flatMap((item, index) => flattenObject(item, `${path}[${index}]`));
                        }
                        return Object.entries(obj).flatMap(([key, val]) => {
                            const nextPath = path ? `${path}.${key}` : key;
                            if (val !== null && typeof val === 'object') {
                                return flattenObject(val, nextPath);
                            }
                            return [{ metric: nextPath, value: val }];
                        });
                    };

                    const csvEscape = (val) => {
                        const str = String(val ?? '');
                        if (str.includes('"') || str.includes(',') || str.includes('\n')) {
                            return '"' + str.replace(/"/g, '""') + '"';
                        }
                        return str;
                    };

                    const toCsv = (payload) => {
                        const data = getData(payload);
                        if (!data) {
                            return '';
                        }
                        const rows = flattenObject(data).map((r) => ({
                            Period: periodInput?.value || '',
                            Metric: r.metric,
                            Value: r.value
                        }));
                        const header = 'Period,Metric,Value';
                        const body = rows.map((r) => `${csvEscape(r.Period)},${csvEscape(r.Metric)},${csvEscape(r.Value)}`);
                        return [header, ...body].join('\n');
                    };

                    const callApi = async () => {
                        if (!endpoint || !periodInput || !statusEl || !resultEl) {
                            return;
                        }

                        toggleDownloads(false);
                        statusEl.textContent = 'Calling...';
                        resultEl.textContent = 'Loading...';

                        if (!periodInput.value) {
                            statusEl.textContent = 'Period is required';
                            resultEl.textContent = 'Please provide period in yyyy-MM-dd format.';
                            return;
                        }

                        const params = new URLSearchParams();
                        params.set('period', periodInput.value);

                        extraParams.forEach((input) => {
                            const key = input.dataset.paramName;
                            const value = input.value?.trim();
                            if (key && value) {
                                params.set(key, value);
                            }
                        });

                        if (formatSelect && formatSelect.value) {
                            params.set('format', formatSelect.value);
                        }

                        const url = `${baseUrl}${endpoint}?${params.toString()}`;

                        try {
                            const res = await fetch(url);
                            const text = await res.text();
                            statusEl.textContent = `Status: ${res.status}`;

                            try {
                                lastPayload = JSON.parse(text);
                                resultEl.textContent = JSON.stringify(lastPayload, null, 2);
                                toggleDownloads(true);
                            } catch (_) {
                                lastPayload = null;
                                resultEl.textContent = text || 'No content';
                                toggleDownloads(false);
                            }
                        } catch (err) {
                            lastPayload = null;
                            statusEl.textContent = 'Call failed';
                            resultEl.textContent = `Error: ${err}`;
                            toggleDownloads(false);
                        }
                    };

                    const downloadJson = () => {
                        if (!lastPayload) {
                            return;
                        }
                        const blob = new Blob([JSON.stringify(lastPayload, null, 2)], { type: 'application/json' });
                        const link = document.createElement('a');
                        link.href = URL.createObjectURL(blob);
                        link.download = `${fileName}.json`;
                        link.click();
                        URL.revokeObjectURL(link.href);
                    };

                    const downloadCsv = () => {
                        if (!lastPayload) {
                            return;
                        }
                        const csv = toCsv(lastPayload);
                        if (!csv) {
                            return;
                        }
                        const blob = new Blob([csv], { type: 'text/csv' });
                        const link = document.createElement('a');
                        link.href = URL.createObjectURL(blob);
                        link.download = `${fileName}.csv`;
                        link.click();
                        URL.revokeObjectURL(link.href);
                    };

                    callBtn?.addEventListener('click', callApi);
                    jsonBtn?.addEventListener('click', downloadJson);
                    csvBtn?.addEventListener('click', downloadCsv);
                });
            };

            // Weekly indicators common try widgets
            const initWeeklyTryWidgets = () => {
                const widgets = document.querySelectorAll('.weekly-try-widget');
                widgets.forEach(widget => {
                    if (widget.dataset.bound === '1') {
                        return;
                    }
                    widget.dataset.bound = '1';

                    const endpoint = widget.dataset.endpoint || '';
                    const fileName = widget.dataset.fileName || 'weekly-indicator';
                    const periodInput = widget.querySelector('.weekly-try-period');
                    const formatSelect = widget.querySelector('.weekly-try-format');
                    const callBtn = widget.querySelector('.weekly-try-call');
                    const statusEl = widget.querySelector('.weekly-try-status');
                    const resultEl = widget.querySelector('.weekly-try-result');
                    const jsonBtn = widget.querySelector('.weekly-try-download-json');
                    const csvBtn = widget.querySelector('.weekly-try-download-csv');
                    const extraParams = Array.from(widget.querySelectorAll('.weekly-try-param'));
                    const baseUrl = '@ViewBag.baseUrl';
                    let lastPayload = null;

                    const toggleDownloads = (enabled) => {
                        if (jsonBtn) {
                            jsonBtn.disabled = !enabled;
                        }
                        if (csvBtn) {
                            csvBtn.disabled = !enabled;
                        }
                    };

                    const getData = (payload) => payload?.Data ?? payload?.data ?? payload ?? null;

                    const flattenObject = (obj, path = '') => {
                        if (obj === null || obj === undefined) {
                            return [];
                        }
                        if (typeof obj !== 'object') {
                            return [{ metric: path || 'value', value: obj }];
                        }
                        if (Array.isArray(obj)) {
                            return obj.flatMap((item, index) => flattenObject(item, `${path}[${index}]`));
                        }
                        return Object.entries(obj).flatMap(([key, val]) => {
                            const nextPath = path ? `${path}.${key}` : key;
                            if (val !== null && typeof val === 'object') {
                                return flattenObject(val, nextPath);
                            }
                            return [{ metric: nextPath, value: val }];
                        });
                    };

                    const csvEscape = (val) => {
                        const str = String(val ?? '');
                        if (str.includes('"') || str.includes(',') || str.includes('\n')) {
                            return '"' + str.replace(/"/g, '""') + '"';
                        }
                        return str;
                    };

                    const toCsv = (payload) => {
                        const data = getData(payload);
                        if (!data) {
                            return '';
                        }
                        const rows = flattenObject(data).map((r) => ({
                            Period: periodInput?.value || '',
                            Metric: r.metric,
                            Value: r.value
                        }));
                        const header = 'Period,Metric,Value';
                        const body = rows.map((r) => `${csvEscape(r.Period)},${csvEscape(r.Metric)},${csvEscape(r.Value)}`);
                        return [header, ...body].join('\n');
                    };

                    const callApi = async () => {
                        if (!endpoint || !periodInput || !statusEl || !resultEl) {
                            return;
                        }

                        toggleDownloads(false);
                        statusEl.textContent = 'Calling...';
                        resultEl.textContent = 'Loading...';

                        if (!periodInput.value?.trim()) {
                            statusEl.textContent = 'Period is required';
                            resultEl.textContent = 'Please provide period value.';
                            return;
                        }

                        const params = new URLSearchParams();
                        params.set('period', periodInput.value.trim());

                        extraParams.forEach((input) => {
                            const key = input.dataset.paramName;
                            const value = input.value?.trim();
                            if (key && value) {
                                params.set(key, value);
                            }
                        });

                        if (formatSelect && formatSelect.value) {
                            params.set('format', formatSelect.value);
                        }

                        const url = `${baseUrl}${endpoint}?${params.toString()}`;

                        try {
                            const res = await fetch(url);
                            const text = await res.text();
                            statusEl.textContent = `Status: ${res.status}`;

                            try {
                                lastPayload = JSON.parse(text);
                                resultEl.textContent = JSON.stringify(lastPayload, null, 2);
                                toggleDownloads(true);
                            } catch (_) {
                                lastPayload = null;
                                resultEl.textContent = text || 'No content';
                                toggleDownloads(false);
                            }
                        } catch (err) {
                            lastPayload = null;
                            statusEl.textContent = 'Call failed';
                            resultEl.textContent = `Error: ${err}`;
                            toggleDownloads(false);
                        }
                    };

                    const downloadJson = () => {
                        if (!lastPayload) {
                            return;
                        }
                        const blob = new Blob([JSON.stringify(lastPayload, null, 2)], { type: 'application/json' });
                        const link = document.createElement('a');
                        link.href = URL.createObjectURL(blob);
                        link.download = `${fileName}.json`;
                        link.click();
                        URL.revokeObjectURL(link.href);
                    };

                    const downloadCsv = () => {
                        if (!lastPayload) {
                            return;
                        }
                        const csv = toCsv(lastPayload);
                        if (!csv) {
                            return;
                        }
                        const blob = new Blob([csv], { type: 'text/csv' });
                        const link = document.createElement('a');
                        link.href = URL.createObjectURL(blob);
                        link.download = `${fileName}.csv`;
                        link.click();
                        URL.revokeObjectURL(link.href);
                    };

                    callBtn?.addEventListener('click', callApi);
                    jsonBtn?.addEventListener('click', downloadJson);
                    csvBtn?.addEventListener('click', downloadCsv);
                });
            };

            initDailyTryWidgets();
            initWeeklyTryWidgets();
        });

        // Auto-highlight syntax
        Prism.highlightAll();
    </script>
