                                    <script>
                                        (() => {
                                            const periodInput = document.getElementById('agriPeriodInput');
                                            const formatSelect = document.getElementById('agriFormatSelect');
                                            const resultEl = document.getElementById('agriResult');
                                            const statusEl = document.getElementById('agriStatus');
                                            const jsonBtn = document.getElementById('agriDownloadJson');
                                            const csvBtn = document.getElementById('agriDownloadCsv');
                                            const callBtn = document.getElementById('agriCallBtn');

                                            const baseUrl = '@ViewBag.baseUrl';
                                            const basePath = baseUrl + '/api/v1/statistics/weekly/economic-indicator/agricultural-production';
                                            let lastPayload = null;

                                            const toggleDownloads = (enabled) => {
                                                jsonBtn.disabled = !enabled;
                                                csvBtn.disabled = !enabled;
                                            };

                                            const getData = (payload) => payload?.data ?? payload?.Data ?? null;
                                            const getPeriod = (payload) => payload?.period ?? payload?.Period ?? '';

                                            const flattenEntries = (obj, path = '') => {
                                                if (obj === null || obj === undefined) {
                                                    return [];
                                                }
                                                if (typeof obj !== 'object') {
                                                    return [{ Metric: path || 'value', Value: obj }];
                                                }
                                                return Object.entries(obj).flatMap(([key, val]) => {
                                                    const nextPath = path ? `${path}.${key}` : key;
                                                    if (val !== null && typeof val === 'object') {
                                                        return flattenEntries(val, nextPath);
                                                    }
                                                    return [{ Metric: nextPath, Value: val }];
                                                });
                                            };

                                            const csvEscape = (val) => {
                                                const str = String(val ?? '');
                                                if (str.includes('"') || str.includes(',') || str.includes('\n')) {
                                                    return '"' + str.replace(/"/g, '""') + '"';
                                                }
                                                return str;
                                            };

                                            const toCsv = (payload) => {
                                                const data = getData(payload);
                                                if (!payload || !data) {
                                                    return '';
                                                }
                                                const period = getPeriod(payload);
                                                const rows = flattenEntries(data).map((r) => ({
                                                    Period: period,
                                                    Metric: r.Metric,
                                                    Value: r.Value
                                                }));
                                                const header = 'Period,Metric,Value';
                                                const body = rows.map((r) => `${csvEscape(r.Period)},${csvEscape(r.Metric)},${csvEscape(r.Value)}`);
                                                return [header, ...body].join('\n');
                                            };

                                            const callApi = async () => {
                                                toggleDownloads(false);
                                                statusEl.textContent = 'Calling...';
                                                resultEl.textContent = 'Loading...';

