                                                }
                                                const rows = [];
                                                const period = getPeriod(payload);
                                                const market = getMarket(payload);

                                                // Handle nested Wholesale/Retail structure
                                                const wholesale = data.Wholesale ?? data.wholesale ?? {};
                                                const retail = data.Retail ?? data.retail ?? {};

                                                Object.entries(wholesale).forEach(([item, value]) => {
                                                    rows.push({
                                                        Period: period,
                                                        Market: market,
                                                        Type: 'Wholesale',
                                                        Item: item,
                                                        Value: value
                                                    });
                                                });

                                                Object.entries(retail).forEach(([item, value]) => {
                                                    rows.push({
                                                        Period: period,
                                                        Market: market,
                                                        Type: 'Retail',
                                                        Item: item,
                                                        Value: value
                                                    });
                                                });

                                                const header = 'Period,Market,Type,Item,Value';
                                                const body = rows.map((r) => `${csvEscape(r.Period)},${csvEscape(r.Market)},${csvEscape(r.Type)},${csvEscape(r.Item)},${r.Value}`);
                                                return [header, ...body].join('\n');
                                            };

                                            const callApi = async () => {
                                                
                                                toggleDownloads(false);
                                                statusEl.textContent = 'Calling...';
                                                resultEl.textContent = 'Loading...';

                                                const params = new URLSearchParams();
                                                params.set('market', marketSelect.value || 'pettah');
                                                if (periodInput.value) {
                                                    params.set('period', periodInput.value);
                                                }
                                                if (formatSelect.value) {
                                                    params.set('format', formatSelect.value);
                                                }

                                                const url = `${basePath}?${params.toString()}`;

                                                try {
                                                    const res = await fetch(url);
                                                    const text = await res.text();
                                                    statusEl.textContent = `Status: ${res.status}`;

                                                    try {
                                                        lastPayload = JSON.parse(text);
                                                        resultEl.textContent = JSON.stringify(lastPayload, null, 2);
                                                        toggleDownloads(!!getData(lastPayload));
                                                    } catch (_) {
                                                        lastPayload = null;
                                                        resultEl.textContent = text || 'No content';
                                                        toggleDownloads(false);
                                                    }
                                                } catch (err) {
                                                    lastPayload = null;
                                                    statusEl.textContent = 'Call failed';
                                                    resultEl.textContent = `Error: ${err}`;
                                                    toggleDownloads(false);
                                                }
                                            };

                                            const downloadJson = () => {
                                                if (!lastPayload) {
                                                    return;
                                                }
                                                const blob = new Blob([JSON.stringify(lastPayload, null, 2)], { type: 'application/json' });
                                                const link = document.createElement('a');
                                                link.href = URL.createObjectURL(blob);
                                                link.download = 'market-prices.json';
                                                link.click();
                                                URL.revokeObjectURL(link.href);
                                            };

                                            const downloadCsv = () => {
                                                if (!lastPayload) {
                                                    return;
                                                }
                                                const csv = toCsv(lastPayload);
                                                if (!csv) {
                                                    return;
                                                }
                                                const blob = new Blob([csv], { type: 'text/csv' });
                                                const link = document.createElement('a');
                                                link.href = URL.createObjectURL(blob);
                                                link.download = 'market-prices.csv';
                                                link.click();
                                                URL.revokeObjectURL(link.href);
                                            };

                                            callBtn.addEventListener('click', callApi);
                                            jsonBtn.addEventListener('click', downloadJson);
                                            csvBtn.addEventListener('click', downloadCsv);
                                        })();
