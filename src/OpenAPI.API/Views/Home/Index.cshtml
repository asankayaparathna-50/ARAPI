                                            <label for="pricePeriodInput" class="form-label">Period (optional)</label>
                                            <input type="date" class="form-control" id="pricePeriodInput" />
                                            <div class="form-text">Defaults to latest available if empty.</div>
                                        </div>
                                        <div class="col-md-4">
                                            <label for="priceFormatSelect" class="form-label">Format</label>
                                            <select class="form-select" id="priceFormatSelect">
                                                <option value="">JSON</option>
                                                <option value="sdmx">SDMX</option>
                                            </select>
                                        </div>
                                    </div>

                                    <div class="d-flex align-items-center gap-2 mb-3">
                                        <button class="btn btn-primary" id="priceCallBtn">Call Endpoint</button>
                                        <span class="text-muted small" id="priceStatus"></span>
                                    </div>

                                    <div class="position-relative" style="max-height: 400px; overflow-y: auto; border: 1px solid #374151; border-radius: 4px;">
                                        <pre class="response-example" style="margin: 0;"><code class="language-json" id="priceResult">Awaiting response...</code></pre>
                                    </div>

                                    <div class="mt-3 d-flex gap-2">
                                        <button class="btn btn-outline-secondary btn-sm" id="priceDownloadJson" disabled>Download JSON</button>
                                        <button class="btn btn-outline-secondary btn-sm" id="priceDownloadCsv" disabled>Download CSV</button>
                                    </div>

                                    <script>
                                        (() => {
                                            const typeSelect = document.getElementById('priceTypeSelect');
                                            const periodInput = document.getElementById('pricePeriodInput');
                                            const formatSelect = document.getElementById('priceFormatSelect');
                                            const resultEl = document.getElementById('priceResult');
                                            const statusEl = document.getElementById('priceStatus');
                                            const jsonBtn = document.getElementById('priceDownloadJson');
                                            const csvBtn = document.getElementById('priceDownloadCsv');
                                            const callBtn = document.getElementById('priceCallBtn');

                                            
                                            const baseUrl = '@ViewBag.baseUrl';
                                            const basePath = baseUrl + '/api/v1/statistics/weekly/economic-indicator/price-indices';
                                            let lastPayload = null;

                                            const toggleDownloads = (enabled) => {
                                                jsonBtn.disabled = !enabled;
                                                csvBtn.disabled = !enabled;
                                            };

                                            const getData = (payload) => payload?.Data ?? payload?.data ?? null;
                                            const getPeriod = (payload) => payload?.Period ?? payload?.period ?? '';
                                            const getType = (payload) => payload?.Type ?? payload?.type ?? '';

                                            const csvEscape = (val) => {
                                                const str = String(val ?? '');
                                                if (str.includes('"') || str.includes(',') || str.includes('\n')) {
                                                    return '"' + str.replace(/"/g, '""') + '"';
                                                }
                                                return str;
                                            };

                                            const toCsv = (payload) => {
                                                const data = getData(payload);
                                                if (!payload || !data) {
                                                    return '';
                                                }
                                                const rows = Object.entries(data).map(([item, value]) => ({
                                                    Period: getPeriod(payload),
                                                    Type: getType(payload),
                                                    Item: item,
                                                    Value: value
                                                }));
                                                const header = 'Period,Type,Item,Value';
                                                const body = rows.map((r) => `${csvEscape(r.Period)},${csvEscape(r.Type)},${csvEscape(r.Item)},${r.Value}`);
                                                return [header, ...body].join('\n');
                                            };

                                            const callApi = async () => {
                                                toggleDownloads(false);
                                                statusEl.textContent = 'Calling...';
                                                resultEl.textContent = 'Loading...';

                                                const params = new URLSearchParams();
                                                params.set('type', typeSelect.value || 'NCPI');
                                                if (periodInput.value) {
                                                    params.set('period', periodInput.value);
                                                }
                                                if (formatSelect.value) {
                                                    params.set('format', formatSelect.value);
                                                }

                                                const url = `${basePath}?${params.toString()}`;
                                                
                                                try {
                                                    const res = await fetch(url);
                                                    const text = await res.text();
                                                    statusEl.textContent = `Status: ${res.status}`;

                                                    try {
                                                        lastPayload = JSON.parse(text);
                                                        resultEl.textContent = JSON.stringify(lastPayload, null, 2);
                                                        toggleDownloads(!!getData(lastPayload));
                                                    } catch (_) {
                                                        lastPayload = null;
                                                        resultEl.textContent = text || 'No content';
                                                        toggleDownloads(false);
                                                    }
                                                } catch (err) {
                                                    lastPayload = null;
                                                    statusEl.textContent = 'Call failed';
                                                    resultEl.textContent = `Error: ${err}`;
                                                    toggleDownloads(false);
                                                }
                                            };

                                            const downloadJson = () => {
                                                if (!lastPayload) {
                                                    return;
                                                }
                                                const blob = new Blob([JSON.stringify(lastPayload, null, 2)], { type: 'application/json' });
                                                const link = document.createElement('a');
                                                link.href = URL.createObjectURL(blob);
                                                link.download = 'price-indices.json';
                                                link.click();
                                                URL.revokeObjectURL(link.href);
                                            };

                                            const downloadCsv = () => {
                                                if (!lastPayload) {
                                                    return;
                                                }
                                                const csv = toCsv(lastPayload);
                                                if (!csv) {
                                                    return;
                                                }
                                                const blob = new Blob([csv], { type: 'text/csv' });
                                                const link = document.createElement('a');
                                                link.href = URL.createObjectURL(blob);
                                                link.download = 'price-indices.csv';
                                                link.click();
                                                URL.revokeObjectURL(link.href);
                                            };

                                            callBtn.addEventListener('click', callApi);
                                            jsonBtn.addEventListener('click', downloadJson);
                                            csvBtn.addEventListener('click', downloadCsv);
                                        })();
                                    </script>
                                </div>

                            </div>

